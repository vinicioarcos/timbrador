# Login propio de la app (no institucional). Genera el hash con:
#   node scripts/hash-password.mjs "TU_CLAVE"
APP_USERNAME=edwin
APP_PASSWORD_HASH=REPLACE_WITH_SCRYPT_HASH

# Secretos largos y aleatorios propios. Genera cada uno con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET
CRON_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET

# PostgreSQL (T-004). En Vercel se provee automáticamente vía la integración
# de Marketplace de Neon ("vercel install neon"); no se gestiona a mano ahí.
DATABASE_URL=

NEXT_PUBLIC_TIMEZONE=America/Guayaquil
PUNCH_INTEGRATION_MODE=mock

# Recordatorios T-3/T+1 (T-005). Cola de entrega diferida, provista
# automáticamente por la integración de Marketplace de Upstash QStash
# ("vercel install upstash/upstash-qstash") — no se gestiona a mano en Vercel.
QSTASH_URL=
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# Web Push (T-005). Generar una sola vez con:
#   node -e "console.log(require('web-push').generateVAPIDKeys())"
# NEXT_PUBLIC_VAPID_PUBLIC_KEY se expone al cliente (no es secreta);
# VAPID_PRIVATE_KEY sí lo es.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:tu-correo@ejemplo.com
